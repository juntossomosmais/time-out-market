{
  "name": "@juntossomosmais/time-out-market",
  "description": "A market of shared JavaScript libraries to help you save time and effort",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "yarn": "please-use-pnpm",
    "npm": "please-use-pnpm",
    "pnpm": ">=10",
    "node": ">=20.19.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "pre-commit": "lint-staged",
    "lint": "eslint . -c eslint.config.mjs",
    "start": "nx run-many --target=start --maxParallel=10",
    "test": "nx run-many --target=test --parallel",
    "test:ci": "nx affected --target=test:ci --base=origin/main --parallel --verbose",
    "test:ci-merge": "nx affected --target=test:ci --base=origin/main~1 --head=origin/main --parallel --verbose"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@juntossomosmais/atomium-tokens": "^2.1.0",
    "@juntossomosmais/linters": "workspace:*",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.40",
    "@swc/helpers": "~0.5.23",
    "@types/jest": "^30.0.0",
    "@types/node": "25.9.1",
    "@types/object-hash": "^3.0.6",
    "@types/pako": "^2.0.4",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "babel-loader": "^10.1.1",
    "benchmark": "^2.1.4",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.7",
    "nx": "22.7.5",
    "patch-package": "^8.0.1",
    "picocolors": "^1.1.1",
    "prettier": "3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^8.1.1",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --cache --fix -c eslint.config.mjs"
    ],
    "*.scss": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "object-hash": "^3.0.0",
    "pako": "^2.1.0",
    "tslib": "^2.8.1"
  }
}
